pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'jdk'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/ayan-mal/Test_repo.git'
            }
        }

        stage('Build') {
            steps {
                dir('First_test') {
                    bat 'mvn clean'
                }
            }
        }

        stage('Compile') {
            steps {
                dir('First_test') {
                    bat 'mvn compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('First_test') {
                    bat 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('First_test') {
                    bat 'mvn package'
                }
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }
    }
}